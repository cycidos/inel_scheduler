{
  "name": "inel_scheduler",
  "version": "1.0.0",
  "description": "Inel Work Scheduler desktop app",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:web": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build:web": "vite build",
    "start": "electron .",
    "seed:chzzk-categories": "node scripts/seed-chzzk-categories.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cycidos/inel_scheduler.git"
  },
  "keywords": [],
  "author": "kimhwan",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/cycidos/inel_scheduler/issues"
  },
  "homepage": "https://github.com/cycidos/inel_scheduler#readme",
  "dependencies": {
    "googleapis": "^171.4.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "wait-on": "^9.0.5"
  }
}
