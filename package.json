{
  "name": "inel_scheduler",
  "version": "1.1.0",
  "description": "Inel Work Scheduler desktop app",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:web": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build:web": "vite build",
    "start": "electron .",
    "seed:chzzk-categories": "node scripts/seed-chzzk-categories.mjs",
    "dist": "npm run dist:admin",
    "dist:admin": "cross-env IWS_EDITION=admin npm run build:web && cross-env IWS_EDITION=admin node scripts/build-edition.mjs",
    "dist:editor": "cross-env IWS_EDITION=editor npm run build:web && cross-env IWS_EDITION=editor node scripts/build-edition.mjs",
    "dist:thumbnailer": "cross-env IWS_EDITION=thumbnailer npm run build:web && cross-env IWS_EDITION=thumbnailer node scripts/build-edition.mjs",
    "dist:dir": "npm run build:web && electron-builder --win --dir"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cycidos/inel_scheduler.git"
  },
  "keywords": [],
  "author": "kimhwan",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/cycidos/inel_scheduler/issues"
  },
  "homepage": "https://github.com/cycidos/inel_scheduler#readme",
  "dependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "googleapis": "^171.4.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-javascript-obfuscator": "^3.1.0",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.inel.scheduler",
    "productName": "Inel Work Scheduler",
    "copyright": "Copyright © 2026 Inel",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "!docs/**",
      "!scripts/**",
      "!build/**",
      "!release/**",
      "!**/*.{ts,tsx,map}",
      "!**/{.eslintrc,.editorconfig,.prettierrc,tsconfig*.json}",
      "!node_modules/**/*.{md,d.ts,map}",
      "!node_modules/**/{test,tests,__tests__,example,examples,sample,samples}/**"
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "data",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "dist/help/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "shortcutName": "Inel Work Scheduler",
      "include": "build/installer.nsh",
      "deleteAppDataOnUninstall": true,
      "runAfterFinish": true
    }
  }
}
